{
  "manifest_version": 3,
  "name": "VNPost BHYT Auto-Lookup",
  "version": "1.0",
  "description": "Tự động tra cứu và lưu thông tin BHYT từ trang VNPost.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://app.hotham.vn/"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.vnpost.vn/qldv/tra-cuu/tra-cuu-thong-tin-the*"
      ],
      "js": ["content.js"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "images/icon16.png",
      "48": "images/icon48.png",
      "128": "images/icon128.png"
    }
  },
  "icons": {
    "16": "images/icon16.png",
    "48": "images/icon48.png",
    "128": "images/icon128.png"
  }
}
